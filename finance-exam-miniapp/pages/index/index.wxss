page{background:#F0F7FF;font-size:14px;color:#212121;height:100vh;overflow:hidden}

/* Layout */
.app-layout{display:flex;height:100vh;overflow:hidden}
.sidebar{width:100px;background:linear-gradient(180deg,#1976D2,#1565C0);color:#fff;display:flex;flex-direction:column;flex-shrink:0;padding-top:12px;overflow-y:auto}
.sidebar-title{font-size:15px;font-weight:700;text-align:center;padding:4px 8px}
.sidebar-sub{font-size:10px;opacity:.7;text-align:center;margin-bottom:12px}
.sidebar-nav{flex:1}
.side-item{display:flex;flex-direction:column;align-items:center;padding:10px 4px;font-size:11px;color:rgba(255,255,255,.7);transition:all .2s}
.side-active{background:rgba(255,255,255,.15);color:#fff;font-weight:600}
.side-icon{font-size:18px;margin-bottom:2px}
.main-content{flex:1;height:100vh;overflow-y:auto}

/* Container */
.container{padding:12px}

/* Banner */
.banner{background:linear-gradient(135deg,#1976D2,#42A5F5);color:#fff;border-radius:12px;padding:16px;margin-bottom:12px}
.banner-title{font-size:17px;font-weight:700}
.banner-sub{font-size:11px;opacity:.8;margin-top:2px}

/* Stats */
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.stat-card{background:#fff;border-radius:10px;padding:12px;box-shadow:0 1px 2px rgba(0,0,0,.04)}
.stat-num{font-size:22px;font-weight:700;color:#1976D2}
.stat-lbl{font-size:10px;color:#757575;margin-top:2px}

/* Card */
.card{background:#fff;border-radius:10px;padding:14px;margin-bottom:10px;box-shadow:0 1px 2px rgba(0,0,0,.04)}
.card-title{font-size:14px;font-weight:600;margin-bottom:6px}
.sub-title{font-size:12px;font-weight:600;color:#757575;margin:10px 0 6px}
.section-title{font-size:16px;font-weight:700;margin-bottom:10px}
.sub{font-size:11px;color:#757575;font-weight:400}
.empty-text{font-size:11px;color:#757575;padding:6px 0}
.footer-text{text-align:center;font-size:11px;color:#757575;margin-top:10px}
.dim-text{font-size:10px;color:#757575}
.q-rate{font-size:12px;color:#757575;margin-top:4px}

/* Progress */
.progress-bar{height:5px;background:#E3F2FD;border-radius:3px;overflow:hidden;margin:6px 0}
.progress-fill{height:100%;background:#1976D2;border-radius:3px}
.progress-legend{display:flex;gap:12px;font-size:10px;color:#757575;margin-top:4px}

/* Guide */
.guide-item{font-size:11px;color:#555;padding:3px 0 3px 12px;position:relative;line-height:1.5}
.guide-item::before{content:'';position:absolute;left:0;top:7px;width:5px;height:5px;background:#1976D2;border-radius:50%}

/* Tree */
.tree-node{margin:1px 0}
.tree-row{display:flex;align-items:center;gap:5px;padding:7px 8px;border-radius:8px;font-size:12px}
.tree-row-indent{padding-left:18px}
.tree-row-indent2{padding-left:32px}
.tree-label{font-size:12px}
.tree-label.bold{font-weight:700}
.tree-count{font-size:10px;color:#757575}
.arrow{font-size:9px;color:#757575;width:14px;flex-shrink:0;display:inline-block;transition:transform .2s}
.arrow.open{transform:rotate(90deg)}
.tree-children{display:none}
.tree-children.open{display:block}
.tree-detail{padding:0}
.kp-detail-card{background:#F0F7FF;border-radius:8px;padding:10px 14px;font-size:11px;color:#555;line-height:1.6;margin:4px 0 4px 32px}

/* Tags */
.tag{display:inline-block;font-size:9px;padding:1px 5px;border-radius:8px;flex-shrink:0}
.tag-green{background:#E8F5E9;color:#2E7D32}
.tag-orange{background:#FFF3E0;color:#E65100}
.tag-blue{background:#E3F2FD;color:#1565C0}

/* Quiz */
.quiz-nav{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px}
.nav-text{font-size:12px;color:#757575}
.q-type{font-size:10px;color:#42A5F5;font-weight:600;margin-bottom:4px}
.q-stem{font-size:13px;line-height:1.6;margin-bottom:8px}
.q-stem-short{font-size:12px;margin-top:4px;color:#333}

/* Options */
.opt-row{display:flex;align-items:center;gap:8px;padding:10px 12px;margin:3px 0;border-radius:10px;border:1.5px solid #E3F2FD;background:#fff;transition:all .15s}
.opt-dot{width:18px;height:18px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:10px;transition:all .2s}
.dot-def{background:#F0F7FF;border:1.5px solid #BBDEFB}
.dot-sel{background:#1976D2;border:1.5px solid #1976D2}
.dot-sel::after{content:'';width:6px;height:6px;background:#fff;border-radius:50%}
.dot-ok{background:#4CAF50;border-color:#4CAF50}
.dot-ok::after{content:'✓';color:#fff;font-size:10px}
.dot-err{background:#F44336;border-color:#F44336}
.dot-err::after{content:'✗';color:#fff;font-size:10px}
.opt-sel{border-color:#1976D2;background:#E3F2FD}
.opt-ok{border-color:#4CAF50;background:#E8F5E9}
.opt-err{border-color:#F44336;background:#FFEBEE}
.opt-text{font-size:12px;flex:1}

.submit-btn{background:#1976D2;color:#fff;border-radius:10px;font-size:13px;font-weight:600;padding:10px 20px;margin-top:10px;border:none;text-align:center}
.submit-btn[disabled]{opacity:.4}
.nav-btn{background:#fff;color:#1976D2;border:1.5px solid #E3F2FD;border-radius:10px;font-size:12px;padding:8px 16px}

.result-banner{border-radius:10px;padding:12px;margin:10px 0;font-size:12px;font-weight:600;display:flex;align-items:center;gap:6px}
.result-correct{background:#E8F5E9;color:#2E7D32}
.result-wrong{background:#FFEBEE;color:#C62828}
.analysis-text{font-size:11px;color:#555;margin-top:6px;line-height:1.5}
.result-icon{font-size:44px;margin-bottom:10px}

.quiz-btns{display:flex;gap:8px;margin-top:8px}

/* Mode cards */
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px}
.mode-card{background:#fff;border-radius:10px;padding:16px 12px;text-align:center;box-shadow:0 1px 2px rgba(0,0,0,.04)}
.mode-icon{font-size:22px;margin-bottom:4px}
.mode-title{font-size:13px;font-weight:600;color:#212121;margin:3px 0}
.mode-desc{font-size:11px;color:#757575}

.chapter-btn{display:block;width:100%;text-align:left;padding:9px 12px;font-size:12px;color:#555;background:none;border:none;border-radius:8px;margin:1px 0;box-sizing:border-box}
.chapter-btn::after{border:none}

/* Search */
.search-input{width:100%;padding:10px 14px;border:1.5px solid #E3F2FD;border-radius:10px;font-size:13px;background:#F0F7FF;box-sizing:border-box;margin-bottom:10px}
.search-card{margin-bottom:6px}
.kp-title{font-size:13px;font-weight:600;color:#212121}
.kp-content{font-size:11px;color:#757575;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* Admin */
.admin-steps{text-align:left;background:#F0F7FF;border-radius:8px;padding:10px;margin-top:10px;font-size:10px;color:#555;line-height:1.7;white-space:pre-line}

/* Chapter progress */
.chap-row{display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px}
