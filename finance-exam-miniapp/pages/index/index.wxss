page{background:#F0F7FF;font-size:14px;color:#212121;padding-bottom:70px}
.container{padding:16px}

/* Banner */
.banner{background:linear-gradient(135deg,#1976D2,#42A5F5);color:#fff;border-radius:12px;padding:18px;margin-bottom:12px}
.banner-title{font-size:18px;font-weight:700}
.banner-sub{font-size:12px;opacity:.8;margin-top:4px}

/* Stats */
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.stat-card{background:#fff;border-radius:12px;padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.stat-num{font-size:24px;font-weight:700;color:#1976D2}
.stat-lbl{font-size:11px;color:#757575;margin-top:2px}

/* Card */
.card{background:#fff;border-radius:12px;padding:16px;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.card-title{font-size:15px;font-weight:600;margin-bottom:8px}
.sub-title{font-size:13px;font-weight:600;color:#757575;margin:12px 0 8px}
.section-title{font-size:16px;font-weight:700;margin-bottom:12px}
.sub{font-size:12px;color:#757575;font-weight:400}
.empty-text{font-size:12px;color:#757575;padding:8px 0}
.footer-text{text-align:center;font-size:12px;color:#757575;margin-top:12px}

/* Progress */
.progress-bar{height:6px;background:#E3F2FD;border-radius:3px;overflow:hidden;margin:8px 0}
.progress-fill{height:100%;background:#1976D2;border-radius:3px;transition:width .3s}
.progress-legend{display:flex;gap:16px;font-size:11px;color:#757575;margin-top:4px}

/* Guide */
.guide-item{display:flex;align-items:flex-start;gap:8px;font-size:12px;color:#555;padding:4px 0;position:relative;padding-left:14px}
.guide-item::before{content:'';position:absolute;left:0;top:8px;width:6px;height:6px;background:#1976D2;border-radius:50%}

/* Tree */
.tree-node{margin:1px 0}
.tree-row{display:flex;align-items:center;gap:6px;padding:8px 10px;border-radius:8px;font-size:13px}
.tree-row-indent{padding-left:20px}
.tree-row-indent2{padding-left:40px}
.tree-label{font-size:13px}
.tree-label.bold{font-weight:700}
.arrow{font-size:10px;color:#757575;width:16px;flex-shrink:0;transition:transform .2s;display:inline-block}
.arrow.open{transform:rotate(90deg)}
.tree-children{display:none}
.tree-children.open{display:block}

/* Tags */
.tag{display:inline-block;font-size:10px;padding:2px 6px;border-radius:10px;flex-shrink:0}
.tag-green{background:#E8F5E9;color:#2E7D32}
.tag-orange{background:#FFF3E0;color:#E65100}
.tag-blue{background:#E3F2FD;color:#1565C0}

/* Tab bar */
.tabbar{position:fixed;bottom:0;left:0;right:0;display:flex;background:#fff;border-top:1px solid #E3F2FD;padding:4px 0 env(safe-area-inset-bottom)}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:4px 0;font-size:10px;color:#757575}
.tab-item text{font-size:10px;margin-top:2px}
.tab-active{color:#1976D2}
.tab-active text{color:#1976D2}

/* Quiz */
.quiz-nav{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.nav-text{font-size:13px;color:#757575}
.q-type{font-size:11px;color:#42A5F5;font-weight:600}
.q-stem{font-size:14px;margin:8px 0;line-height:1.6}
.q-stem-short{font-size:13px;margin-top:4px;color:#333}

.option{display:block;width:100%;text-align:left;padding:10px 14px;margin:4px 0;border:1.5px solid #E3F2FD;border-radius:10px;background:#fff;font-size:13px;box-sizing:border-box}
.option-selected{border-color:#1976D2;background:#E3F2FD}
.option-correct{border-color:#4CAF50;background:#E8F5E9}
.option-wrong{border-color:#F44336;background:#FFEBEE}

.submit-btn{background:#1976D2;color:#fff;border-radius:10px;font-size:13px;font-weight:600;padding:10px 20px;margin-top:12px;border:none;text-align:center}
.submit-btn[disabled]{opacity:.4}
.nav-btn{background:#fff;color:#1976D2;border:1.5px solid #E3F2FD;border-radius:10px;font-size:13px;padding:10px 20px}

.result-banner{border-radius:10px;padding:14px;margin:12px 0;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px}
.result-correct{background:#E8F5E9;color:#2E7D32}
.result-wrong{background:#FFEBEE;color:#C62828}
.analysis-text{font-size:12px;color:#555;margin-top:6px;line-height:1.5}
.result-icon{font-size:48px;margin-bottom:12px}

.quiz-btns{display:flex;gap:8px;margin-top:8px}

/* Practice mode cards */
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.mode-card{background:#fff;border-radius:12px;padding:20px 14px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.mode-icon{font-size:24px;margin-bottom:6px}
.mode-title{font-size:14px;font-weight:600;color:#212121;margin:4px 0}
.mode-desc{font-size:12px;color:#757575}

.chapter-btn{display:block;width:100%;text-align:left;padding:10px 14px;font-size:13px;color:#555;background:none;border:none;border-radius:8px;margin:2px 0;box-sizing:border-box}
.chapter-btn::after{border:none}

/* Search */
.search-input{width:100%;padding:12px 16px;border:1.5px solid #E3F2FD;border-radius:12px;font-size:14px;background:#F0F7FF;box-sizing:border-box;margin-bottom:12px}
.search-card{margin-bottom:8px}
.kp-title{font-size:14px;font-weight:600;color:#212121}
.kp-content{font-size:12px;color:#757575;margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* Admin */
.admin-steps{text-align:left;background:#F0F7FF;border-radius:8px;padding:12px;margin-top:12px;font-size:11px;color:#555;line-height:1.8}

/* Analysis */
.chap-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px}
